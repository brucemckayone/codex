{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ecom-api",
  "main": "dist/index.js",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],

  // Observability configuration
  "observability": {
    "enabled": true
  },

  // Cron Triggers (scheduled handler)
  // - Every 15 minutes — payouts sweep (Codex-vv77x): drains pending payouts
  //   whose Connect account is now charges_enabled && payouts_enabled.
  //   Hybrid event+sweep resolution per Stripe docs (account.updated webhook
  //   + periodic reconciliation). Consolidated into ecom-api 2026-05-13 so
  //   Stripe cron + Stripe webhooks colocate in one Worker.
  "triggers": {
    "crons": ["*/15 * * * *"]
  },

  // KV Namespaces
  "kv_namespaces": [
    {
      "binding": "RATE_LIMIT_KV",
      "id": "cea7153364974737b16870df08f31083"
    },
    {
      "binding": "AUTH_SESSION_KV",
      "id": "82d04a4236df4aac8e9d87793344f0ed"
    },
    {
      "binding": "CACHE_KV",
      "id": "c5e85d4c8ecb46f9a3e5d4d96a14e9f1"
    }
  ],

  // Default environment variables (local development)
  "vars": {
    "ENVIRONMENT": "development",
    "DB_METHOD": "LOCAL_PROXY",
    "WEB_APP_URL": "http://lvh.me:3000",
    "API_URL": "http://localhost:8787"
  },

  // Environment configurations
  "env": {
    // Test environment (E2E tests)
    // Note: DB_METHOD is set via .dev.vars.test (NEON_BRANCH in CI, LOCAL_PROXY locally)
    "test": {
      "name": "ecom-api-test",
      "vars": {
        "ENVIRONMENT": "test",
        "DB_METHOD": "LOCAL_PROXY",
        "WEB_APP_URL": "http://lvh.me:3000",
        "API_URL": "http://localhost:8787"
      },
      "kv_namespaces": [
        {
          "binding": "RATE_LIMIT_KV",
          "id": "cea7153364974737b16870df08f31083"
        },
        {
          "binding": "AUTH_SESSION_KV",
          "id": "82d04a4236df4aac8e9d87793344f0ed"
        },
        {
          "binding": "CACHE_KV",
          "id": "c5e85d4c8ecb46f9a3e5d4d96a14e9f1"
        }
      ]
    },

    // Production environment
    "production": {
      "name": "ecom-api-production",
      "triggers": {
        "crons": ["*/15 * * * *"]
      },
      "vars": {
        "ENVIRONMENT": "production",
        "DB_METHOD": "PRODUCTION",
        "WEB_APP_URL": "https://codex.revelations.studio",
        "AUTH_WORKER_URL": "https://auth.revelations.studio"
      },
      "kv_namespaces": [
        {
          "binding": "RATE_LIMIT_KV",
          "id": "cea7153364974737b16870df08f31083"
        },
        {
          "binding": "AUTH_SESSION_KV",
          "id": "82d04a4236df4aac8e9d87793344f0ed"
        },
        {
          "binding": "CACHE_KV",
          "id": "c5e85d4c8ecb46f9a3e5d4d96a14e9f1"
        }
      ],
      "routes": [
        {
          "pattern": "ecom-api.revelations.studio/*",
          "zone_name": "revelations.studio"
        }
      ]
    },

    // Staging environment
    "staging": {
      "name": "ecom-api-staging",
      "triggers": {
        "crons": ["*/15 * * * *"]
      },
      "vars": {
        "ENVIRONMENT": "staging",
        "WEB_APP_URL": "https://codex-staging.revelations.studio",
        "AUTH_WORKER_URL": "https://auth-staging.revelations.studio"
      },
      "kv_namespaces": [
        {
          "binding": "RATE_LIMIT_KV",
          "id": "cea7153364974737b16870df08f31083"
        },
        {
          "binding": "AUTH_SESSION_KV",
          "id": "82d04a4236df4aac8e9d87793344f0ed"
        },
        {
          "binding": "CACHE_KV",
          "id": "c5e85d4c8ecb46f9a3e5d4d96a14e9f1"
        }
      ],
      "routes": [
        {
          "pattern": "ecom-api-staging.revelations.studio/*",
          "custom_domain": true
        }
      ]
    },

    // Deployed dev environment (long-lived dev.revelations.studio)
    // Stripe: dev should use Stripe test-mode keys + a dedicated webhook
    // signing secret. Set via `wrangler secret put STRIPE_SECRET_KEY --env dev`
    // and the four STRIPE_WEBHOOK_SECRET_* secrets.
    "dev": {
      "name": "ecom-api-dev",
      "triggers": {
        "crons": ["*/15 * * * *"]
      },
      "vars": {
        "ENVIRONMENT": "dev",
        "DB_METHOD": "PRODUCTION",
        "WEB_APP_URL": "https://dev.revelations.studio",
        "AUTH_WORKER_URL": "https://auth.dev.revelations.studio"
      },
      "kv_namespaces": [
        {
          "binding": "RATE_LIMIT_KV",
          "id": "cea7153364974737b16870df08f31083"
        },
        {
          "binding": "AUTH_SESSION_KV",
          "id": "82d04a4236df4aac8e9d87793344f0ed"
        },
        {
          "binding": "CACHE_KV",
          "id": "8bde7d718cff4bfa99e29cd8e0aa7353"
        }
      ],
      "routes": [
        {
          "pattern": "ecom-api.dev.revelations.studio/*",
          "zone_name": "revelations.studio"
        }
      ]
    }
  }

  // ==========================================================================
  // Environment Variables & Secrets
  // ==========================================================================
  //
  // Local Development:
  //   Create .dev.vars file with required secrets (see .dev.vars.example)
  //
  // Test Environment:
  //   Uses .dev.vars.test (already configured with test values)
  //
  // Production Secrets (set via wrangler CLI):
  //   wrangler secret put DATABASE_URL --env production
  //   wrangler secret put STRIPE_SECRET_KEY --env production
  //   wrangler secret put STRIPE_WEBHOOK_SECRET_BOOKING --env production
  //
  // Required Variables:
  //   - DATABASE_URL: PostgreSQL connection string
  //   - STRIPE_SECRET_KEY: Stripe API secret key
  //   - STRIPE_WEBHOOK_SECRET_BOOKING: Webhook signing secret for checkout
  //   - RATE_LIMIT_KV: KV namespace binding (configured above)
}
