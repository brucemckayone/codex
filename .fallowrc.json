{
  "$schema": "https://docs.fallow.tools/schema/fallow.schema.json",
  "entry": [
    "vite.config.ts",
    "vitest.config.ts",
    "**/vite.config.ts",
    "**/vite.config.*.ts",
    "**/vitest.config.ts",
    "**/vitest.config.*.ts",
    "config/vite/**/*.ts",
    "config/vitest/**/*.ts",
    "apps/web/svelte.config.js",
    "apps/web/playwright.config.ts",
    "apps/web/.storybook/**/*.ts",
    "apps/web/src/tests/setup.ts",
    "apps/web/e2e/**/*.spec.ts"
  ],
  "ignoreDependencies": ["vite-plugin-dts"],
  "dynamicallyLoaded": [
    "**/*.stories.svelte",
    "**/*.stories.ts",
    "**/*.stories.js",
    "apps/web/src/paraglide/**",
    "apps/web/src/routes/**/+page.server.ts",
    "apps/web/src/routes/**/+page.ts",
    "apps/web/src/routes/**/+page.svelte",
    "apps/web/src/routes/**/+layout.server.ts",
    "apps/web/src/routes/**/+layout.ts",
    "apps/web/src/routes/**/+layout.svelte",
    "apps/web/src/routes/**/+server.ts",
    "apps/web/src/routes/**/+error.svelte",
    "apps/web/src/hooks.ts",
    "apps/web/src/hooks.server.ts",
    "apps/web/src/hooks.client.ts",
    "apps/web/src/app.html"
  ],
  "ignorePatterns": [
    "test-media/**",
    ".claude/worktrees/**",
    "**/worker-configuration.d.ts",
    "**/.vite-temp/**",
    "docs/**",
    "**/dist/**",
    "**/build/**",
    "**/.svelte-kit/**",
    "apps/web/src/paraglide/**"
  ],
  "usedClassMembers": [
    "alarm",
    "clearMessages",
    "createCreatorTemplate",
    "createGlobalTemplate",
    "createMultipartUpload",
    "createOrgTemplate",
    "delete",
    "deleteCreatorTemplate",
    "deleteGlobalTemplate",
    "deleteIntroVideo",
    "deleteOrgTemplate",
    "fetch",
    "followOrganization",
    "formatPurchasesForClient",
    "free",
    "generateSignedUploadUrl",
    "generateSignedUrl",
    "get",
    "getBytesWebP",
    "getExpectedOutputKeys",
    "getFollowerCount",
    "getIntroVideoStatus",
    "getMessages",
    "getProfile",
    "getPublicStats",
    "getTemplateById",
    "getTranscodingStatus",
    "getUserOrganizations",
    "get_height",
    "get_width",
    "handleAccountDeauthorized",
    "isFollowing",
    "isSlugAvailable",
    "linkIntroVideo",
    "list",
    "listCreatorTemplates",
    "listOrgTemplates",
    "name",
    "previewTemplateById",
    "putJson",
    "recoverStuckTranscoding",
    "resize",
    "resolvePendingPayouts",
    "resumeMultipartUpload",
    "retryTranscoding",
    "setCache",
    "setCachePurge",
    "syncAccountStatus",
    "unfollowOrganization",
    "updateCreatorTemplate",
    "updateGlobalTemplate",
    "updateOrgTemplate",
    "upgradeToCreator",
    "upload"
  ],
  "duplicates": {
    "enabled": true,
    "mode": "mild",
    "minTokens": 50,
    "minLines": 5,
    "ignore": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/__tests__/**",
      "**/e2e/**",
      "**/*.d.ts"
    ]
  },
  "rules": {
    "duplicate-exports": "off"
  }
}
