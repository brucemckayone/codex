# Local Transcoding Environment
# Used by: docker run --env-file local.env codex-transcoder-local
#
# host.docker.internal resolves to the Docker host machine,
# allowing the container to reach dev-cdn and MinIO on the host.

# R2 storage — served by dev-cdn's S3-compatible interface (Miniflare R2)
R2_ENDPOINT=http://host.docker.internal:4100
R2_ACCESS_KEY_ID=miniflare
R2_SECRET_ACCESS_KEY=miniflare
R2_BUCKET_NAME=codex-media-test
ASSETS_BUCKET_NAME=codex-assets-test

# B2 storage — served by MinIO (mezzanine archival)
B2_ENDPOINT=http://host.docker.internal:9000
B2_ACCESS_KEY_ID=minioadmin
B2_SECRET_ACCESS_KEY=minioadmin
B2_BUCKET_NAME=codex-mezzanine-dev

# Webhook secret for signing callbacks to media-api
WEBHOOK_SECRET=local-webhook-secret-for-testing

# RunPod SDK — serve as API (listen on port 8000) instead of test mode
RUNPOD_SERVE_API=true
